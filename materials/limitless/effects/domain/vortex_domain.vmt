"Sprite"
{
	"$basetexture" "limitless/effects/domain/vortex_domain"
	"$spriteorientation" "vp_parallel"
	"$spriteorigin" "[ 0.50 0.50 ]"
	"$translucent" "1"
	"$nocull" "1"
	"$vertexcolor" "1"
	"$vertexalpha" "1"

	"Proxies"

	{

	"UniformNoise"
		{

		"minVal" "1"
		"maxVal" "23"
		"resultvar" "$frame"

		}


		"AnimatedTexture"
		{

		"animatedTextureVar" "$basetexture"
		"animatedTextureFrameNumVar" "$frame"
		"animatedTextureFrameRate" "50"

		}
	}
}