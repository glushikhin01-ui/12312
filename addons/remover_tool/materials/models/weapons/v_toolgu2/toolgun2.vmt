"VertexLitGeneric"
{
	"$basetexture" "models/weapons/v_toolgu2/toolgun2"
	"$halflambert"			"1"
	"$lightwarptexture"		"models/weapons/v_toolgu2/toolgunlw"

	"$selfillum" 1 
	"$model" 1
	"$envmapmask" "models/weapons/v_toolgun/toolgun2_mask" 
	"$envmap" "env_cubemap"
	"$envmapcontrast" 1
	"$envmaptint" "[0.6 0.6 0.6]" 

	// Phong Stuff
	"$phong" "1"
	"$phongexponent" "30"
	"$phongexponenttexture" "models\weapons\phong"
	"$phongwarptexture"  "models/effects/phongwarp_library/iridescence009"
	"$phongboost" "4"
	"$phongfresnelranges" "[1 0.5 1]"
	"$phongalbedotint" "1"

	// Rim lighting parameters
	"$rimlight" "1"				// To enable rim lighting (requires phong)
	"$rimlightexponent" "70"             // Exponent for phong component of rim lighting
	"$rimlightboost" "0.7"

	"Proxies"
	{
                              "AnimatedTexture" 
                               { 
                               "animatedTextureVar" "$basetexture"  
                               "animatedTextureFrameNumVar" "$frame" 
                               "animatedTextureFrameRate" "3" 
                                }
	}
}
